#compdef fire

_fire_cli() {
  local -a lines
  local -a entries
  local line value note

  lines=("${(@f)$(fire __complete -- "${words[@]}")}")
  (( ${#lines[@]} == 0 )) && return 1

  for line in "${lines[@]}"; do
    if [[ "$line" == *$'\t'* ]]; then
      value="${line%%$'\t'*}"
      note="${line#*$'\t'}"
      entries+=("$value:$note")
    else
      entries+=("$line:")
    fi
  done

  _describe 'fire commands' entries
}

compdef _fire_cli fire
